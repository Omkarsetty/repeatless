# App Server Settings
PORT=3001
JWT_SECRET=your_jwt_secret_here

# Google OAuth Credentials (Gmail API)
# Created in Google Cloud Console under Credentials -> OAuth client ID
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Supabase API Credentials
# Used for general Supabase API queries
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Postgres Connection String
# Used for direct database operations and vector operations via pg Pool
# Format: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=your_supabase_postgres_db_url_here

# Primary AI Model - Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Secondary AI Model - NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
